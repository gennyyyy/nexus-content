NEXUS_ENV="development"
NEXUS_DATABASE_URL="sqlite:///backend/database.db"
NEXUS_CORS_ORIGINS="http://127.0.0.1:5173,http://localhost:5173"
NEXUS_PUBLIC_API_BASE_URL="http://127.0.0.1:8000/api"
NEXUS_PUBLIC_MCP_BASE_URL="http://127.0.0.1:8000/mcp"
NEXUS_REQUEST_LOGGING_ENABLED="true"
NEXUS_REQUEST_LOGGING_INCLUDE_QUERY_STRING="false"
NEXUS_REQUEST_LOG_LEVEL="INFO"
NEXUS_REQUEST_ID_HEADER_NAME="X-Request-ID"
